{
  "name": "@bendyline/squisq-video-react",
  "version": "1.0.1",
  "description": "React components for browser-based video export of Squisq documents via WebCodecs",
  "license": "MIT",
  "author": "Bendyline",
  "repository": {
    "type": "git",
    "url": "https://github.com/bendyline/squisq.git",
    "directory": "packages/video-react"
  },
  "homepage": "https://github.com/bendyline/squisq",
  "keywords": [
    "squisq",
    "video",
    "mp4",
    "react",
    "webcodecs",
    "export"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@bendyline/squisq": "1.1.1",
    "@bendyline/squisq-video": "1.0.1",
    "@bendyline/squisq-react": "1.0.3",
    "html2canvas": "^1.4.1",
    "mp4-muxer": "^5.1.3"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
