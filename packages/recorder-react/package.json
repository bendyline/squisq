{
  "name": "@bendyline/squisq-recorder-react",
  "version": "0.1.0",
  "description": "React components for browser-based audio, video, and screen recording into Squisq ContentContainers",
  "license": "MIT",
  "author": "Bendyline",
  "repository": {
    "type": "git",
    "url": "https://github.com/bendyline/squisq.git",
    "directory": "packages/recorder-react"
  },
  "homepage": "https://github.com/bendyline/squisq",
  "keywords": [
    "squisq",
    "recorder",
    "react",
    "mediarecorder",
    "getusermedia",
    "getdisplaymedia",
    "audio",
    "video",
    "screen-capture"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "concurrently -n js,dts -c blue,gray -r \"tsup --watch --no-dts --no-clean\" \"tsup --watch --dts-only --no-clean\"",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@bendyline/squisq": "1.3.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
