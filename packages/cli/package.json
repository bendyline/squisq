{
  "name": "@bendyline/squisq-cli",
  "version": "1.1.0",
  "description": "Squisq CLI — convert markdown documents to DOCX, PDF, HTML, and more",
  "license": "MIT",
  "author": "Bendyline",
  "repository": {
    "type": "git",
    "url": "https://github.com/bendyline/squisq.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/bendyline/squisq",
  "keywords": [
    "squisq",
    "markdown",
    "docx",
    "pdf",
    "html",
    "converter",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "squisq": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js",
      "default": "./dist/api.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "mocha"
  },
  "dependencies": {
    "@bendyline/squisq": "1.2.0",
    "@bendyline/squisq-formats": "1.2.0",
    "@bendyline/squisq-react": "1.1.0",
    "@bendyline/squisq-video": "1.0.2",
    "commander": "4.1.1",
    "playwright-core": "1.58.2"
  },
  "devDependencies": {
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "chai": "5.3.3",
    "mocha": "11.7.5",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
