{
  "name": "@bendyline/squisq-react",
  "version": "1.1.2",
  "description": "React component library for doc playback, block rendering, and media layers",
  "license": "MIT",
  "author": "Bendyline",
  "repository": {
    "type": "git",
    "url": "https://github.com/bendyline/squisq.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/bendyline/squisq",
  "keywords": [
    "react",
    "doc-player",
    "block-renderer",
    "svg",
    "animation",
    "video"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./src/styles/doc-animations.css",
    "./standalone": "./dist/squisq-player.global.js",
    "./standalone-source": {
      "types": "./dist/standalone-source.d.ts",
      "import": "./dist/standalone-source.js"
    }
  },
  "scripts": {
    "build": "tsup && tsup --config tsup.standalone.config.ts && node scripts/generate-standalone-source.mjs",
    "build:esm": "tsup",
    "build:standalone": "tsup --config tsup.standalone.config.ts && node scripts/generate-standalone-source.mjs",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@bendyline/squisq": "1.2.2"
  },
  "devDependencies": {
    "@types/react": "18.3.28",
    "preact": "10.29.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "jsdom": "25.0.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
