{
  "name": "@bendyline/squisq-react",
  "version": "1.0.0",
  "description": "React component library for doc playback, block rendering, and media layers",
  "license": "MIT",
  "author": "Bendyline",
  "repository": {
    "type": "git",
    "url": "https://github.com/bendyline/squisq.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/bendyline/squisq",
  "keywords": [
    "react",
    "doc-player",
    "block-renderer",
    "svg",
    "animation",
    "video"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./src/styles/doc-animations.css",
    "./standalone": "./dist/squisq-player.global.js",
    "./standalone-source": {
      "import": "./dist/standalone-source.js",
      "types": "./dist/standalone-source.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsup --config tsup.standalone.config.ts && node scripts/generate-standalone-source.mjs",
    "build:esm": "tsup",
    "build:standalone": "tsup --config tsup.standalone.config.ts && node scripts/generate-standalone-source.mjs",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@bendyline/squisq": "1.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "preact": "^10.25.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "jsdom": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
