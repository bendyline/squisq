{
  "name": "@bendyline/squisq-editor-react",
  "version": "1.3.0",
  "description": "React editor shell with raw/WYSIWYG/preview modes for Squisq documents",
  "license": "MIT",
  "author": "Bendyline",
  "repository": {
    "type": "git",
    "url": "https://github.com/bendyline/squisq.git",
    "directory": "packages/editor-react"
  },
  "homepage": "https://github.com/bendyline/squisq",
  "keywords": [
    "editor",
    "react",
    "markdown",
    "wysiwyg",
    "monaco",
    "tiptap"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./src/styles/editor.css"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "monaco-editor": "^0.50.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@bendyline/squisq": "1.3.0",
    "@bendyline/squisq-formats": "1.2.3",
    "@bendyline/squisq-react": "1.2.0",
    "@monaco-editor/react": "4.7.0",
    "@tiptap/extension-image": "2.27.2",
    "@tiptap/extension-mention": "2.27.2",
    "@tiptap/extension-placeholder": "2.27.2",
    "@tiptap/extension-table": "2.27.2",
    "@tiptap/extension-table-cell": "2.27.2",
    "@tiptap/extension-table-header": "2.27.2",
    "@tiptap/extension-table-row": "2.27.2",
    "@tiptap/extension-task-item": "2.27.2",
    "@tiptap/extension-task-list": "2.27.2",
    "@tiptap/pm": "2.27.2",
    "@tiptap/react": "2.27.2",
    "@tiptap/starter-kit": "2.27.2",
    "@tiptap/suggestion": "2.27.2"
  },
  "devDependencies": {
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
