{
  "name": "squisq",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "all": "npm install && npm run build && npm run lint && npm run format:check && npm run typecheck && npm test && npm run test:cli && npm run test:e2e",
    "build": "npm run build:core && npm run build:formats && npm run build:react && npm run build:video && npm run build:editor && npm run build:cli",
    "build:core": "npm run build -w @bendyline/squisq",
    "build:formats": "npm run build -w @bendyline/squisq-formats",
    "build:react": "npm run build -w @bendyline/squisq-react",
    "build:video": "npm run build -w @bendyline/squisq-video",
    "build:editor": "npm run build -w @bendyline/squisq-editor-react",
    "build:cli": "npm run build -w @bendyline/squisq-cli",
    "test": "vitest run",
    "test:cli": "npm test -w @bendyline/squisq-cli",
    "test:e2e": "playwright test",
    "site": "npm run build && npm run dev -w squisq-site",
    "dev": "npm run dev -w squisq-site",
    "typecheck": "tsc -b packages/core packages/formats packages/react packages/video packages/editor-react packages/cli",
    "clean": "rimraf packages/*/dist",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prettierfix": "prettier --write .",
    "release": "multi-semantic-release"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^15.0.0",
    "multi-semantic-release": "^3.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "semantic-release": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
