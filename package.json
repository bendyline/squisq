{
  "name": "squisq",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "all": "npm install && npm run build && npm test",
    "build": "npm run build:core && npm run build:formats && npm run build:react && npm run build:editor",
    "build:core": "npm run build -w @bendyline/squisq",
    "build:formats": "npm run build -w @bendyline/squisq-formats",
    "build:react": "npm run build -w @bendyline/squisq-react",
    "build:editor": "npm run build -w @bendyline/squisq-editor-react",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "site": "npm run build && npm run dev -w squisq-site",
    "dev": "npm run dev -w squisq-site",
    "typecheck": "tsc -b packages/core packages/formats packages/react packages/editor-react",
    "clean": "rimraf packages/*/dist"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
